{
  "scripts": {
    "build:css": "tailwindcss -i input.css -o shield/dashboard/static/shield.min.css --minify && node -e \"const f='shield/dashboard/static/shield.min.css',fs=require('fs');fs.writeFileSync(f,fs.readFileSync(f,'utf8').trimEnd())\"",
    "watch:css": "tailwindcss -i input.css -o shield/dashboard/static/shield.min.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.1"
  }
}
